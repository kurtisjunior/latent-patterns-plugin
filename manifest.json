{
  "manifest_version": 2,
  "name": "Site Styling",
  "version": "1.0.0",
  "description": "Apply consistent typography and colors to websites for comfortable reading",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["src/background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_action": {
    "default_title": "Toggle Site Styling"
  },
  "options_page": "src/options/options.html",
  "commands": {
    "toggle-global": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Toggle extension globally"
    },
    "toggle-site": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Toggle extension on current site"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{12345678-1234-1234-1234-123456789012}",
      "strict_min_version": "60.0"
    }
  }
}
